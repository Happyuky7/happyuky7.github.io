        "**/dist": false,
        "**/en": true,
        "**/es": true,
        "**/ja": true,
        "**/fr": true,
        "**/de": true,
        "**/pt": true,
        "**/pl": true,
        "**/ru": true,
        "**/zh": true,
        "**/ko": true,
        "**/th": true,
        "**/fil": true
    }
}
